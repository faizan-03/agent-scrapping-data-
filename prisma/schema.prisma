generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum JobStatus {
  NEW
  MATCHED
  EXPORTED
  APPLIED
  REJECTED
  ARCHIVED
}

enum RunStatus {
  RUNNING
  SUCCESS
  FAILED
}

model Job {
  id             String    @id @default(cuid())
  title          String
  company        String
  location       String?
  url            String    @unique
  source         String
  description    String?
  salary         String?
  recruiterEmail String?
  score          Int?
  status         JobStatus @default(NEW)
  coverLetter    String?
  resumeVariant  String?
  postedAt       DateTime?
  discoveredAt   DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([score])
  @@index([source])
  @@index([status])
  @@index([discoveredAt])
}

model CronRun {
  id            String    @id @default(cuid())
  status        RunStatus @default(RUNNING)
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?
  sources       String[]
  scrapedCount  Int       @default(0)
  matchedCount  Int       @default(0)
  exportedCount Int       @default(0)
  error         String?
}
